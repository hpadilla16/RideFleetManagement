// Rental agreement addendum (BUG-001 Option C). Post-signature date
// changes create a new addendum row instead of mutating the signed parent.
model RentalAgreementAddendum {
  id                String          @id @default(cuid())
  rentalAgreementId String
  rentalAgreement   RentalAgreement @relation(fields: [rentalAgreementId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  pickupAt DateTime
  returnAt DateTime

  reason         String
  reasonCategory String? @default("admin_correction")

  initiatedBy     String?
  initiatedByRole String?

  status String @default("PENDING_SIGNATURE")

  signatureSignedBy String?
  signatureDataUrl  String?
  signatureSignedAt DateTime?
  signatureIp       String?

  // Token-based public signing flow (BUG-001 customer self-service follow-up).
  // Generated at addendum creation, embedded in the customer notification
  // email, consumed (set to null) after a successful signature submission.
  signatureToken          String?   @unique
  signatureTokenExpiresAt DateTime?

  originalCharges String?
  newCharges      String?
  chargeDelta     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rentalAgreementId])
  @@index([tenantId, status])
  @@index([status, createdAt])
  @@index([tenantId, createdAt])
}

model Trip {
