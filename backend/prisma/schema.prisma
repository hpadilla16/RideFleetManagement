generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  ON_RENT
  IN_MAINTENANCE
  OUT_OF_SERVICE
}

enum ReservationStatus {
  NEW
  CONFIRMED
  CHECKED_OUT
  CHECKED_IN
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  VOID
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPS
  AGENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ADMIN_OVERRIDE
}

enum RentalAgreementStatus {
  DRAFT
  READY_FOR_CHECKOUT
  FINALIZED
  CLOSED
  CANCELLED
}

enum ChargeType {
  UNIT
  DAILY
  TAX
  PERCENT
  DEPOSIT
}

enum AgreementPaymentMethod {
  CASH
  CARD
  ZELLE
  ATH_MOVIL
  BANK_TRANSFER
  OTHER
}

enum ReservationPaymentOrigin {
  OTC
  PORTAL
  IMPORTED
  MIGRATED_NOTE
}

enum InspectionPhase {
  CHECKOUT
  CHECKIN
}

enum FeeMode {
  FIXED
  PER_DAY
  PERCENTAGE
}

enum CommissionValueType {
  PERCENT
  FIXED_PER_UNIT
  FIXED_PER_AGREEMENT
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  VOID
}

enum RateType {
  MULTIPLE_CLASSES
  SINGLE_CLASS
}

enum VehicleOwnershipType {
  FLEET_OWNED
  HOST_OWNED
}

enum VehicleBlockType {
  MIGRATION_HOLD
  MAINTENANCE_HOLD
  WASH_HOLD
  OUT_OF_SERVICE_HOLD
}

enum VehicleFleetMode {
  RENTAL_ONLY
  CAR_SHARING_ONLY
  BOTH
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum ListingFulfillmentMode {
  PICKUP_ONLY
  DELIVERY_ONLY
  PICKUP_OR_DELIVERY
}

enum CarSharingSearchPlaceType {
  AIRPORT
  HOTEL
  NEIGHBORHOOD
  STATION
  TENANT_BRANCH
  HOST_PICKUP_SPOT
  DELIVERY_ZONE
}

enum CarSharingPlaceVisibilityMode {
  APPROXIMATE_ONLY
  REVEAL_AFTER_BOOKING
  PUBLIC_EXACT
}

enum HostServiceAreaType {
  PICKUP
  DELIVERY
  BOTH
}

enum TripFulfillmentChoice {
  PICKUP
  DELIVERY
}

enum TripHandoffMode {
  IN_PERSON
  LOCKBOX
  REMOTE_UNLOCK
  SELF_SERVICE
}

enum TripStatus {
  INQUIRY
  RESERVED
  CONFIRMED
  READY_FOR_PICKUP
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum TripPayoutStatus {
  PENDING
  ON_HOLD
  APPROVED
  PAID
  VOID
}

enum TripIncidentType {
  DAMAGE
  TOLL
  CLEANING
  LATE_RETURN
  OTHER
}

enum TripIncidentStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum TripIncidentPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TripIncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TripIncidentResolutionCode {
  CUSTOMER_CHARGED
  WAIVED
  INVALID_REPORT
  DUPLICATE
  GOODWILL
  OTHER
}

enum TripIncidentLiabilityDecision {
  PENDING
  CUSTOMER
  TENANT
  HOST
  SHARED
  WAIVED
}

enum TripIncidentChargeDecision {
  PENDING
  CHARGE_CUSTOMER
  CHARGE_HOST
  CHARGE_TENANT
  WAIVE
}

enum TripIncidentRecoveryStage {
  INTAKE
  EVIDENCE
  LIABILITY_REVIEW
  READY_TO_CHARGE
  CHARGED
  WAIVED
  CLOSED
}

enum HostReviewStatus {
  REQUESTED
  SUBMITTED
}

enum ReservationWorkflowMode {
  RENTAL
  CAR_SHARING
  DEALERSHIP_LOANER
}

enum LoanerBillingMode {
  COURTESY
  CUSTOMER_PAY
  WARRANTY
  INSURANCE
  INTERNAL
}

enum LoanerBillingStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  INVOICED
  SETTLED
  DENIED
}

enum TollProvider {
  AUTOEXPRESO
  SUNPASS
}

enum TollTransactionStatus {
  IMPORTED
  MATCHED
  NEEDS_REVIEW
  BILLED
  DISPUTED
  VOID
}

enum TollMatchStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
  AUTO_CONFIRMED
}

enum TollBillingStatus {
  PENDING
  POSTED_TO_RESERVATION
  POSTED_TO_AGREEMENT
  WAIVED
  DISPUTED
}

enum HostVehicleSubmissionStatus {
  PENDING_REVIEW
  PENDING_INFO
  APPROVED
  REJECTED
}

enum PlannerActionType {
  ASSIGN_VEHICLE
  UNASSIGN_VEHICLE
  MOVE_RESERVATION_TIME
  CREATE_WASH_BLOCK
  CREATE_MAINTENANCE_BLOCK
  CREATE_OUT_OF_SERVICE_BLOCK
}

enum PlannerRecommendationType {
  VEHICLE_ASSIGNMENT
  REBALANCE
  OVERBOOKING_ALERT
  FLEET_SHORTAGE
  MAINTENANCE_SLOT
  WASH_SLOT
}

enum PlannerRuleMode {
  STRICT
  FLEXIBLE
}

model Tenant {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  status                  String   @default("ACTIVE")
  plan                    String   @default("BETA")
  carSharingEnabled       Boolean  @default(false)
  dealershipLoanerEnabled Boolean  @default(false)
  tollsEnabled            Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users                       User[]
  locations                   Location[]
  vehicleTypes                VehicleType[]
  vehicles                    Vehicle[]
  vehicleAvailabilityBlocks   VehicleAvailabilityBlock[]
  customers                   Customer[]
  reservations                Reservation[]
  auditLogs                   AuditLog[]
  agreements                  RentalAgreement[]
  rates                       Rate[]
  fees                        Fee[]
  services                    AdditionalService[]
  commissionPlans             CommissionPlan[]
  commissionRules             CommissionRule[]
  agreementCommissions        AgreementCommission[]
  hostProfiles                HostProfile[]
  hostPickupSpots             HostPickupSpot[]
  carSharingSearchPlaces      CarSharingSearchPlace[]
  hostServiceAreas            HostServiceArea[]
  carSharingListings          HostVehicleListing[]
  carSharingTrips             Trip[]
  tripFulfillmentPlans        TripFulfillmentPlan[]
  tripPayouts                 TripPayout[]
  hostVehicleSubmissions      HostVehicleSubmission[]
  tollProviderAccounts        TollProviderAccount[]
  tollTransactions            TollTransaction[]
  tollAssignments             TollAssignment[]
  tollImportRuns              TollImportRun[]
  telematicsDevices           VehicleTelematicsDevice[]
  telematicsEvents            VehicleTelematicsEvent[]
  plannerRuleSet              PlannerRuleSet?
  plannerScenarios            PlannerScenario[]
  plannerRecommendationAudits PlannerRecommendationAudit[]
  conversations               Conversation[]
  knowledgeArticles           KnowledgeArticle[]
  franchises                  Franchise[]
  agreementAddendums          RentalAgreementAddendum[]
  vehicleClassStopSales       VehicleClassStopSale[]
}

model Location {
  id             String   @id @default(cuid())
  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  code           String
  name           String
  address        String?
  city           String?
  state          String?
  country        String?
  taxRate        Decimal  @default(0) @db.Decimal(5, 2)
  isActive       Boolean  @default(true)
  locationConfig String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehiclesHome                   Vehicle[]               @relation("VehicleHomeLocation")
  reservationsPickup             Reservation[]           @relation("ReservationPickupLocation")
  reservationsReturn             Reservation[]           @relation("ReservationReturnLocation")
  agreementsPickup               RentalAgreement[]       @relation("AgreementPickupLocation")
  agreementsReturn               RentalAgreement[]       @relation("AgreementReturnLocation")
  additionalServices             AdditionalService[]
  locationFees                   LocationFee[]
  rates                          Rate[]
  carSharingListings             HostVehicleListing[]
  hostVehicleSubmissionPreferred HostVehicleSubmission[]
  hostPickupSpotsAnchor          HostPickupSpot[]        @relation("HostPickupSpotAnchorLocation")
  carSharingSearchPlacesAnchor   CarSharingSearchPlace[] @relation("CarSharingSearchPlaceAnchorLocation")
  carSharingPickupTrips          Trip[]                  @relation("TripPickupLocation")
  carSharingReturnTrips          Trip[]                  @relation("TripReturnLocation")

  @@unique([tenantId, code])
  @@index([tenantId])
}

model VehicleType {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  code        String
  name        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicles               Vehicle[]
  reservations           Reservation[]
  rateItems              RateItem[]
  rateDailyPrices        RateDailyPrice[]
  hostVehicleSubmissions HostVehicleSubmission[]
  vehicleClassStopSales  VehicleClassStopSale[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Vehicle {
  id                String           @id @default(cuid())
  tenantId          String?
  tenant            Tenant?          @relation(fields: [tenantId], references: [id])
  internalNumber    String
  vin               String?          @unique
  plate             String?
  tollTagNumber     String?
  tollStickerNumber String?
  make              String?
  model             String?
  year              Int?
  color             String?
  mileage           Int              @default(0)
  status            VehicleStatus    @default(AVAILABLE)
  fleetMode         VehicleFleetMode @default(RENTAL_ONLY)

  vehicleTypeId String
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id])

  homeLocationId String?
  homeLocation   Location? @relation("VehicleHomeLocation", fields: [homeLocationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations          Reservation[]
  maintenanceJobs       MaintenanceJob[]
  rentalAgreements      RentalAgreement[]
  hostListing           HostVehicleListing?
  hostVehicleSubmission HostVehicleSubmission?
  tollTransactions      TollTransaction[]
  tollAssignments       TollAssignment[]
  availabilityBlocks    VehicleAvailabilityBlock[]
  telematicsDevices     VehicleTelematicsDevice[]
  telematicsEvents      VehicleTelematicsEvent[]

  @@unique([tenantId, plate])
  @@unique([tenantId, internalNumber])
  @@index([tenantId, status])
}

model VehicleAvailabilityBlock {
  id            String           @id @default(cuid())
  tenantId      String?
  tenant        Tenant?          @relation(fields: [tenantId], references: [id])
  vehicleId     String
  vehicle       Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  blockType     VehicleBlockType @default(MIGRATION_HOLD)
  blockedFrom   DateTime         @default(now())
  availableFrom DateTime
  reason        String?
  notes         String?
  sourceType    String?
  releasedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tenantId, vehicleId, blockedFrom, availableFrom])
  @@index([vehicleId, releasedAt, availableFrom])
}

// Website-only stop-sale: hide a vehicle class from the public booking
// website for a date range without affecting backoffice/manual reservations.
// The existing VehicleAvailabilityBlock model (per-VIN, blocks ALL channels)
// is unchanged - this is a separate concept on purpose.
model VehicleClassStopSale {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  vehicleTypeId String
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  reason        String?
  notes         String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId, vehicleTypeId, isActive, startDate, endDate])
  @@index([tenantId, isActive])
}

model VehicleTelematicsDevice {
  id               String    @id @default(cuid())
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id])
  vehicleId        String
  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  provider         String
  externalDeviceId String
  label            String?
  serialNumber     String?
  isActive         Boolean   @default(true)
  installedAt      DateTime?
  lastSeenAt       DateTime?
  metadataJson     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  events VehicleTelematicsEvent[]

  @@unique([provider, externalDeviceId])
  @@index([tenantId, vehicleId, isActive])
}

model VehicleTelematicsEvent {
  id          String                   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?                  @relation(fields: [tenantId], references: [id])
  vehicleId   String
  vehicle     Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  deviceId    String?
  device      VehicleTelematicsDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  eventType   String                   @default("PING")
  eventAt     DateTime
  latitude    Decimal?                 @db.Decimal(9, 6)
  longitude   Decimal?                 @db.Decimal(9, 6)
  speedMph    Decimal?                 @db.Decimal(8, 2)
  heading     Int?
  odometer    Int?
  fuelPct     Decimal?                 @db.Decimal(5, 2)
  batteryPct  Decimal?                 @db.Decimal(5, 2)
  engineOn    Boolean?
  payloadJson String?
  createdAt   DateTime                 @default(now())

  @@index([tenantId, vehicleId, eventAt])
  @@index([deviceId, eventAt])
}

model Customer {
  id                       String    @id @default(cuid())
  tenantId                 String?
  tenant                   Tenant?   @relation(fields: [tenantId], references: [id])
  firstName                String
  lastName                 String
  email                    String?
  phone                    String
  licenseNumber            String?
  licenseState             String?
  dateOfBirth              DateTime?
  insurancePolicyNumber    String?
  insuranceDocumentUrl     String?
  address1                 String?
  address2                 String?
  city                     String?
  state                    String?
  zip                      String?
  country                  String?
  idPhotoUrl               String?
  authnetCustomerProfileId String?
  authnetPaymentProfileId  String?
  creditBalance            Decimal   @default(0) @db.Decimal(10, 2)
  portalResetToken         String?
  portalResetExpiresAt     DateTime?
  guestAccessToken         String?
  guestAccessExpiresAt     DateTime?
  deletionToken            String?   @unique
  deletionTokenExpiresAt   DateTime?
  doNotRent                Boolean   @default(false)
  doNotRentReason          String?
  notes                    String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  reservations  Reservation[]
  guestTrips    Trip[]         @relation("TripGuestCustomer")
  hostReviews   HostReview[]
  conversations Conversation[]

  @@index([tenantId])
  @@index([tenantId, lastName])
  @@index([lastName, firstName])
  @@index([phone])
  @@index([email])
}

model Reservation {
  id                              String                  @id @default(cuid())
  tenantId                        String?
  tenant                          Tenant?                 @relation(fields: [tenantId], references: [id])
  reservationNumber               String                  @unique
  sourceRef                       String?                 @unique
  status                          ReservationStatus       @default(NEW)
  workflowMode                    ReservationWorkflowMode @default(RENTAL)
  loanerBillingMode               LoanerBillingMode?
  repairOrderNumber               String?
  claimNumber                     String?
  serviceAdvisorName              String?
  serviceAdvisorEmail             String?
  serviceAdvisorPhone             String?
  serviceStartAt                  DateTime?
  estimatedServiceCompletionAt    DateTime?
  serviceVehicleYear              Int?
  serviceVehicleMake              String?
  serviceVehicleModel             String?
  serviceVehiclePlate             String?
  serviceVehicleVin               String?
  loanerLiabilityAccepted         Boolean                 @default(false)
  loanerLiabilityAcceptedAt       DateTime?
  loanerProgramNotes              String?
  loanerBorrowerPacketJson        String?
  loanerBorrowerPacketCompletedAt DateTime?
  loanerBorrowerPacketCompletedBy String?
  loanerBillingContactName        String?
  loanerBillingContactEmail       String?
  loanerBillingContactPhone       String?
  loanerBillingAuthorizationRef   String?
  loanerBillingNotes              String?
  loanerReturnExceptionFlag       Boolean                 @default(false)
  loanerReturnExceptionNotes      String?
  loanerBillingStatus             LoanerBillingStatus     @default(DRAFT)
  loanerBillingSubmittedAt        DateTime?
  loanerBillingSettledAt          DateTime?
  serviceAdvisorNotes             String?
  serviceAdvisorUpdatedAt         DateTime?
  loanerServiceCompletedAt        DateTime?
  loanerServiceCompletedBy        String?
  loanerCloseoutNotes             String?
  loanerPurchaseOrderNumber       String?
  loanerDealerInvoiceNumber       String?
  loanerAccountingNotes           String?
  loanerAccountingClosedAt        DateTime?
  loanerAccountingClosedBy        String?
  loanerLastExtendedAt            DateTime?
  loanerLastVehicleSwapAt         DateTime?

  bookingChannel String @default("STAFF")

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  vehicleTypeId String?
  vehicleType   VehicleType? @relation(fields: [vehicleTypeId], references: [id])

  pickupAt DateTime
  returnAt DateTime

  pickupLocationId String
  pickupLocation   Location @relation("ReservationPickupLocation", fields: [pickupLocationId], references: [id])

  returnLocationId String
  returnLocation   Location @relation("ReservationReturnLocation", fields: [returnLocationId], references: [id])

  franchiseId String?
  franchise   Franchise? @relation("ReservationFranchise", fields: [franchiseId], references: [id])

  dailyRate      Decimal?      @db.Decimal(10, 2)
  estimatedTotal Decimal?      @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(PENDING)

  sendConfirmationEmail        Boolean   @default(true)
  notes                        String?
  customerInfoToken            String?
  customerInfoTokenExpiresAt   DateTime?
  customerInfoCompletedAt      DateTime?
  customerInfoReviewedAt       DateTime?
  customerInfoReviewedByUserId String?
  customerInfoReviewedByUser   User?     @relation("ReservationCustomerInfoReviewedBy", fields: [customerInfoReviewedByUserId], references: [id])
  customerInfoReviewNote       String?
  readyForPickupAt             DateTime?
  readyForPickupByUserId       String?
  readyForPickupByUser         User?     @relation("ReservationReadyForPickupBy", fields: [readyForPickupByUserId], references: [id])
  readyForPickupOverrideNote   String?
  signatureToken               String?
  signatureTokenExpiresAt      DateTime?
  paymentRequestToken          String?
  paymentRequestTokenExpiresAt DateTime?
  signatureSignedAt            DateTime?
  signatureSignedBy            String?
  signatureDataUrl             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices          Invoice[]
  auditLogs         AuditLog[]
  rentalAgreement   RentalAgreement?
  pricingSnapshot   ReservationPricingSnapshot?
  charges           ReservationCharge[]
  payments          ReservationPayment[]
  additionalDrivers ReservationAdditionalDriver[]
  carSharingTrip    Trip?
  incidents         TripIncident[]
  hostReviews       HostReview[]
  tollTransactions  TollTransaction[]
  tollAssignments   TollAssignment[]

  @@index([status, pickupAt])
  @@index([workflowMode, status, pickupAt])
  @@index([pickupLocationId, pickupAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, pickupAt])
  @@index([repairOrderNumber])
  @@index([customerId])
  @@index([returnAt])
  @@index([tenantId, status, returnAt])
  @@index([vehicleId])
}

model Invoice {
  id            String      @id @default(cuid())
  invoiceNumber String      @unique
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  subtotal Decimal       @db.Decimal(10, 2)
  taxes    Decimal       @db.Decimal(10, 2)
  fees     Decimal       @db.Decimal(10, 2)
  total    Decimal       @db.Decimal(10, 2)
  status   PaymentStatus @default(PENDING)

  issuedAt  DateTime  @default(now())
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([reservationId])
}

model MaintenanceJob {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  title          String
  description    String?
  status         MaintenanceStatus @default(OPEN)
  odometerAtOpen Int?
  costEstimate   Decimal?          @db.Decimal(10, 2)
  finalCost      Decimal?          @db.Decimal(10, 2)
  openedAt       DateTime          @default(now())
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId, status])
}

model HostVehicleListing {
  id                  String                 @id @default(cuid())
  tenantId            String?
  tenant              Tenant?                @relation(fields: [tenantId], references: [id])
  hostProfileId       String
  hostProfile         HostProfile            @relation(fields: [hostProfileId], references: [id])
  vehicleId           String                 @unique
  vehicle             Vehicle                @relation(fields: [vehicleId], references: [id])
  locationId          String?
  location            Location?              @relation(fields: [locationId], references: [id])
  pickupSpotId        String?
  pickupSpot          HostPickupSpot?        @relation(fields: [pickupSpotId], references: [id])
  slug                String                 @unique
  title               String
  shortDescription    String?
  description         String?
  status              ListingStatus          @default(DRAFT)
  ownershipType       VehicleOwnershipType   @default(HOST_OWNED)
  currency            String                 @default("USD")
  fulfillmentMode     ListingFulfillmentMode @default(PICKUP_ONLY)
  baseDailyRate       Decimal                @default(0) @db.Decimal(10, 2)
  cleaningFee         Decimal                @default(0) @db.Decimal(10, 2)
  pickupFee           Decimal                @default(0) @db.Decimal(10, 2)
  deliveryFee         Decimal                @default(0) @db.Decimal(10, 2)
  deliveryRadiusMiles Int?
  deliveryAreasJson   String?
  deliveryNotes       String?
  securityDeposit     Decimal                @default(0) @db.Decimal(10, 2)
  instantBook         Boolean                @default(false)
  minTripDays         Int                    @default(1)
  maxTripDays         Int?
  tripRules           String?
  photosJson          String?
  addOnsJson          String?
  publishedAt         DateTime?
  pausedAt            DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  availabilityWindows ListingAvailabilityWindow[]
  serviceAreas        HostServiceArea[]
  trips               Trip[]
  vehicleSubmission   HostVehicleSubmission?

  @@index([tenantId, status])
  @@index([hostProfileId, status])
  @@index([locationId, status])
  @@index([pickupSpotId, status])
}

model HostVehicleSubmission {
  id                           String                      @id @default(cuid())
  tenantId                     String?
  tenant                       Tenant?                     @relation(fields: [tenantId], references: [id])
  hostProfileId                String
  hostProfile                  HostProfile                 @relation(fields: [hostProfileId], references: [id])
  vehicleTypeId                String
  vehicleType                  VehicleType                 @relation(fields: [vehicleTypeId], references: [id])
  preferredLocationId          String?
  preferredLocation            Location?                   @relation(fields: [preferredLocationId], references: [id])
  preferredPickupSpotId        String?
  preferredPickupSpot          HostPickupSpot?             @relation(fields: [preferredPickupSpotId], references: [id])
  year                         Int?
  make                         String?
  model                        String?
  color                        String?
  vin                          String?
  plate                        String?
  mileage                      Int                         @default(0)
  fulfillmentMode              ListingFulfillmentMode      @default(PICKUP_ONLY)
  baseDailyRate                Decimal                     @default(0) @db.Decimal(10, 2)
  cleaningFee                  Decimal                     @default(0) @db.Decimal(10, 2)
  pickupFee                    Decimal                     @default(0) @db.Decimal(10, 2)
  deliveryFee                  Decimal                     @default(0) @db.Decimal(10, 2)
  deliveryRadiusMiles          Int?
  deliveryAreasJson            String?
  deliveryNotes                String?
  securityDeposit              Decimal                     @default(0) @db.Decimal(10, 2)
  minTripDays                  Int                         @default(1)
  maxTripDays                  Int?
  shortDescription             String?
  description                  String?
  tripRules                    String?
  photosJson                   String?
  insuranceDocumentUrl         String?
  registrationDocumentUrl      String?
  initialInspectionDocumentUrl String?
  initialInspectionNotes       String?
  addOnsJson                   String?
