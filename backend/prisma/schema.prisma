generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  ON_RENT
  IN_MAINTENANCE
  OUT_OF_SERVICE
}

enum ReservationStatus {
  NEW
  CONFIRMED
  CHECKED_OUT
  CHECKED_IN
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  VOID
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPS
  AGENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ADMIN_OVERRIDE
}

enum RentalAgreementStatus {
  DRAFT
  READY_FOR_CHECKOUT
  FINALIZED
  CLOSED
  CANCELLED
}

enum ChargeType {
  UNIT
  DAILY
  TAX
  PERCENT
  DEPOSIT
}

enum AgreementPaymentMethod {
  CASH
  CARD
  ZELLE
  ATH_MOVIL
  BANK_TRANSFER
  OTHER
}

enum ReservationPaymentOrigin {
  OTC
  PORTAL
  IMPORTED
  MIGRATED_NOTE
}

enum InspectionPhase {
  CHECKOUT
  CHECKIN
}

enum FeeMode {
  FIXED
  PER_DAY
  PERCENTAGE
}

enum CommissionValueType {
  PERCENT
  FIXED_PER_UNIT
  FIXED_PER_AGREEMENT
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  VOID
}

enum RateType {
  MULTIPLE_CLASSES
  SINGLE_CLASS
}

enum VehicleOwnershipType {
  FLEET_OWNED
  HOST_OWNED
}

enum VehicleFleetMode {
  RENTAL_ONLY
  CAR_SHARING_ONLY
  BOTH
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum TripStatus {
  INQUIRY
  RESERVED
  CONFIRMED
  READY_FOR_PICKUP
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum TripPayoutStatus {
  PENDING
  ON_HOLD
  APPROVED
  PAID
  VOID
}

enum TripIncidentType {
  DAMAGE
  TOLL
  CLEANING
  LATE_RETURN
  OTHER
}

enum TripIncidentStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE")
  plan      String   @default("BETA")
  carSharingEnabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  locations    Location[]
  vehicleTypes VehicleType[]
  vehicles     Vehicle[]
  customers    Customer[]
  reservations Reservation[]
  auditLogs    AuditLog[]
  agreements   RentalAgreement[]
  rates        Rate[]
  fees         Fee[]
  services     AdditionalService[]
  commissionPlans CommissionPlan[]
  commissionRules CommissionRule[]
  agreementCommissions AgreementCommission[]
  hostProfiles HostProfile[]
  carSharingListings HostVehicleListing[]
  carSharingTrips Trip[]
  tripPayouts TripPayout[]
}

model Location {
  id        String    @id @default(cuid())
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])
  code      String    @unique
  name      String
  address   String?
  city      String?
  state     String?
  country   String?
  taxRate   Decimal   @default(0) @db.Decimal(5, 2)
  isActive  Boolean   @default(true)
  locationConfig String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vehiclesHome       Vehicle[]         @relation("VehicleHomeLocation")
  reservationsPickup Reservation[]     @relation("ReservationPickupLocation")
  reservationsReturn Reservation[]     @relation("ReservationReturnLocation")
  agreementsPickup   RentalAgreement[] @relation("AgreementPickupLocation")
  agreementsReturn   RentalAgreement[] @relation("AgreementReturnLocation")
  additionalServices AdditionalService[]
  locationFees       LocationFee[]
  rates              Rate[]
  carSharingListings HostVehicleListing[]
  carSharingPickupTrips Trip[] @relation("TripPickupLocation")
  carSharingReturnTrips Trip[] @relation("TripReturnLocation")
}

model VehicleType {
  id           String     @id @default(cuid())
  tenantId     String?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])
  code         String
  name         String
  description  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  vehicles     Vehicle[]
  reservations Reservation[]
  rateItems    RateItem[]

  @@unique([tenantId, code])
}

model Vehicle {
  id             String        @id @default(cuid())
  tenantId       String?
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])
  internalNumber String        @unique
  vin            String?       @unique
  plate          String?       @unique
  make           String?
  model          String?
  year           Int?
  color          String?
  mileage        Int           @default(0)
  status         VehicleStatus @default(AVAILABLE)
  fleetMode      VehicleFleetMode @default(RENTAL_ONLY)

  vehicleTypeId  String
  vehicleType    VehicleType   @relation(fields: [vehicleTypeId], references: [id])

  homeLocationId String?
  homeLocation   Location?     @relation("VehicleHomeLocation", fields: [homeLocationId], references: [id])

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  reservations    Reservation[]
  maintenanceJobs MaintenanceJob[]
  rentalAgreements RentalAgreement[]
  hostListing     HostVehicleListing?
}

model Customer {
  id              String   @id @default(cuid())
  tenantId        String?
  tenant          Tenant?  @relation(fields: [tenantId], references: [id])
  firstName       String
  lastName        String
  email           String?
  phone           String
  licenseNumber   String?
  licenseState    String?
  dateOfBirth     DateTime?
  insurancePolicyNumber String?
  insuranceDocumentUrl  String?
  address1        String?
  address2        String?
  city            String?
  state           String?
  zip             String?
  country         String?
  idPhotoUrl      String?
  authnetCustomerProfileId String?
  authnetPaymentProfileId  String?
  creditBalance   Decimal  @default(0) @db.Decimal(10, 2)
  portalResetToken String?
  portalResetExpiresAt DateTime?
  doNotRent       Boolean  @default(false)
  doNotRentReason String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservations    Reservation[]
  guestTrips      Trip[] @relation("TripGuestCustomer")

  @@index([lastName, firstName])
  @@index([phone])
  @@index([email])
}

model Reservation {
  id                String            @id @default(cuid())
  tenantId          String?
  tenant            Tenant?           @relation(fields: [tenantId], references: [id])
  reservationNumber String            @unique
  sourceRef         String?           @unique
  status            ReservationStatus @default(NEW)

  customerId        String
  customer          Customer          @relation(fields: [customerId], references: [id])

  vehicleId         String?
  vehicle           Vehicle?          @relation(fields: [vehicleId], references: [id])

  vehicleTypeId     String?
  vehicleType       VehicleType?      @relation(fields: [vehicleTypeId], references: [id])

  pickupAt          DateTime
  returnAt          DateTime

  pickupLocationId  String
  pickupLocation    Location          @relation("ReservationPickupLocation", fields: [pickupLocationId], references: [id])

  returnLocationId  String
  returnLocation    Location          @relation("ReservationReturnLocation", fields: [returnLocationId], references: [id])

  dailyRate         Decimal?          @db.Decimal(10, 2)
  estimatedTotal    Decimal?          @db.Decimal(10, 2)
  paymentStatus     PaymentStatus     @default(PENDING)

  sendConfirmationEmail Boolean       @default(true)
  notes             String?
  customerInfoToken String?
  customerInfoTokenExpiresAt DateTime?
  customerInfoCompletedAt DateTime?
  customerInfoReviewedAt DateTime?
  customerInfoReviewedByUserId String?
  customerInfoReviewedByUser User? @relation("ReservationCustomerInfoReviewedBy", fields: [customerInfoReviewedByUserId], references: [id])
  customerInfoReviewNote String?
  readyForPickupAt DateTime?
  readyForPickupByUserId String?
  readyForPickupByUser User? @relation("ReservationReadyForPickupBy", fields: [readyForPickupByUserId], references: [id])
  readyForPickupOverrideNote String?
  signatureToken    String?
  signatureTokenExpiresAt DateTime?
  paymentRequestToken String?
  paymentRequestTokenExpiresAt DateTime?
  signatureSignedAt  DateTime?
  signatureSignedBy  String?
  signatureDataUrl   String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  invoices          Invoice[]
  auditLogs         AuditLog[]
  rentalAgreement   RentalAgreement?
  pricingSnapshot   ReservationPricingSnapshot?
  charges           ReservationCharge[]
  payments          ReservationPayment[]
  additionalDrivers ReservationAdditionalDriver[]
  carSharingTrip    Trip?

  @@index([status, pickupAt])
  @@index([pickupLocationId, pickupAt])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  reservationId  String
  reservation    Reservation   @relation(fields: [reservationId], references: [id])

  subtotal       Decimal       @db.Decimal(10, 2)
  taxes          Decimal       @db.Decimal(10, 2)
  fees           Decimal       @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)

  issuedAt       DateTime      @default(now())
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([reservationId])
}

model MaintenanceJob {
  id            String            @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle           @relation(fields: [vehicleId], references: [id])

  title         String
  description   String?
  status        MaintenanceStatus @default(OPEN)
  odometerAtOpen Int?
  costEstimate  Decimal?          @db.Decimal(10, 2)
  finalCost     Decimal?          @db.Decimal(10, 2)
  openedAt      DateTime          @default(now())
  completedAt   DateTime?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([vehicleId, status])
}

model HostVehicleListing {
  id                String              @id @default(cuid())
  tenantId          String?
  tenant            Tenant?             @relation(fields: [tenantId], references: [id])
  hostProfileId     String
  hostProfile       HostProfile         @relation(fields: [hostProfileId], references: [id])
  vehicleId         String              @unique
  vehicle           Vehicle             @relation(fields: [vehicleId], references: [id])
  locationId        String?
  location          Location?           @relation(fields: [locationId], references: [id])
  slug              String              @unique
  title             String
  shortDescription  String?
  description       String?
  status            ListingStatus       @default(DRAFT)
  ownershipType     VehicleOwnershipType @default(HOST_OWNED)
  currency          String              @default("USD")
  baseDailyRate     Decimal             @default(0) @db.Decimal(10, 2)
  cleaningFee       Decimal             @default(0) @db.Decimal(10, 2)
  deliveryFee       Decimal             @default(0) @db.Decimal(10, 2)
  securityDeposit   Decimal             @default(0) @db.Decimal(10, 2)
  instantBook       Boolean             @default(false)
  minTripDays       Int                 @default(1)
  maxTripDays       Int?
  tripRules         String?
  photosJson        String?
  publishedAt       DateTime?
  pausedAt          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  availabilityWindows ListingAvailabilityWindow[]
  trips             Trip[]

  @@index([tenantId, status])
  @@index([hostProfileId, status])
  @@index([locationId, status])
}

model ListingAvailabilityWindow {
  id                 String            @id @default(cuid())
  listingId          String
  listing            HostVehicleListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startAt            DateTime
  endAt              DateTime
  isBlocked          Boolean           @default(false)
  priceOverride      Decimal?          @db.Decimal(10, 2)
  minTripDaysOverride Int?
  note               String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([listingId, startAt, endAt])
}

model User {
  id           String   @id @default(cuid())
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  email        String   @unique
  passwordHash String
  lockPinHash  String?
  lockPinUpdatedAt DateTime?
  fullName     String
  role         UserRole @default(AGENT)
  isActive     Boolean  @default(true)
  commissionPlanId String?
  commissionPlan   CommissionPlan? @relation("UserCommissionPlan", fields: [commissionPlanId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    AuditLog[]
  salesOwnedAgreements RentalAgreement[] @relation("AgreementSalesOwner")
  closedAgreements RentalAgreement[] @relation("AgreementClosedBy")
  agreementCommissions AgreementCommission[] @relation("AgreementCommissionEmployee")
  customerInfoReviewedReservations Reservation[] @relation("ReservationCustomerInfoReviewedBy")
  readyForPickupReservations Reservation[] @relation("ReservationReadyForPickupBy")
  hostProfile HostProfile?

  @@index([tenantId, role, isActive])
  @@index([commissionPlanId])
}

model HostProfile {
  id                String    @id @default(cuid())
  tenantId          String?
  tenant            Tenant?   @relation(fields: [tenantId], references: [id])
  userId            String?   @unique
  user              User?     @relation(fields: [userId], references: [id])
  displayName       String
  legalName         String?
  email             String?
  phone             String?
  status            String    @default("ACTIVE")
  payoutProvider    String?
  payoutAccountRef  String?
  payoutEnabled     Boolean   @default(false)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  listings          HostVehicleListing[]
  trips             Trip[]    @relation("TripHost")
  payouts           TripPayout[]

  @@index([tenantId, status])
  @@index([email])
}

model AuditLog {
  id            String      @id @default(cuid())
  tenantId      String?
  tenant        Tenant?     @relation(fields: [tenantId], references: [id])
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  action        AuditAction
  actorUserId   String?
  actorUser     User?       @relation(fields: [actorUserId], references: [id])

  fromStatus    ReservationStatus?
  toStatus      ReservationStatus?
  reason        String?
  metadata      String?

  createdAt     DateTime    @default(now())

  @@index([reservationId, createdAt])
  @@index([action, createdAt])
}

model RentalAgreement {
  id                String                @id @default(cuid())
  tenantId          String?
  tenant            Tenant?               @relation(fields: [tenantId], references: [id])
  agreementNumber   String                @unique
  status            RentalAgreementStatus @default(DRAFT)

  reservationId     String                @unique
  reservation       Reservation           @relation(fields: [reservationId], references: [id])

  vehicleId         String?
  vehicle           Vehicle?              @relation(fields: [vehicleId], references: [id])

  pickupAt          DateTime
  returnAt          DateTime

  pickupLocationId  String
  pickupLocation    Location              @relation("AgreementPickupLocation", fields: [pickupLocationId], references: [id])

  returnLocationId  String
  returnLocation    Location              @relation("AgreementReturnLocation", fields: [returnLocationId], references: [id])

  customerFirstName String
  customerLastName  String
  customerEmail     String?
  customerPhone     String?
  customerAddress1  String?
  customerAddress2  String?
  customerCity      String?
  customerState     String?
  customerZip       String?
  customerCountry   String?
  dateOfBirth       DateTime?
  licenseNumber     String?
  licenseState      String?
  licenseExpiry     DateTime?
  insuranceSource   String?
  insurancePolicyNumber String?
  insuranceDocumentUrl  String?
  insurancePlanCode  String?
  insurancePlanName  String?
  insurancePlanRate  Decimal?              @db.Decimal(10, 2)

  odometerOut       Int?
  odometerIn        Int?
  fuelOut           Decimal?              @db.Decimal(4, 2)
  fuelIn            Decimal?              @db.Decimal(4, 2)
  cleanlinessOut    Int?
  cleanlinessIn     Int?

  subtotal          Decimal               @default(0) @db.Decimal(10, 2)
  taxes             Decimal               @default(0) @db.Decimal(10, 2)
  fees              Decimal               @default(0) @db.Decimal(10, 2)
  total             Decimal               @default(0) @db.Decimal(10, 2)
  deposit           Decimal               @default(0) @db.Decimal(10, 2)
  securityDepositAmount Decimal           @default(0) @db.Decimal(10, 2)
  securityDepositCaptured Boolean         @default(false)
  securityDepositCapturedAt DateTime?
  securityDepositReleasedAt DateTime?
  securityDepositReference String?
  paidAmount        Decimal               @default(0) @db.Decimal(10, 2)
  balance           Decimal               @default(0) @db.Decimal(10, 2)

  paymentMethod     AgreementPaymentMethod?
  paymentReference  String?

  notes             String?
  finalizedAt       DateTime?
  closedAt          DateTime?
  salesOwnerUserId  String?
  salesOwnerUser    User?                  @relation("AgreementSalesOwner", fields: [salesOwnerUserId], references: [id])
  closedByUserId    String?
  closedByUser      User?                  @relation("AgreementClosedBy", fields: [closedByUserId], references: [id])
  locked            Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  drivers           AgreementDriver[]
  charges           RentalAgreementCharge[]
  payments          RentalAgreementPayment[]
  inspections       RentalAgreementInspection[]
  commissions       AgreementCommission[]

  @@index([status, pickupAt])
}

model Trip {
  id                String           @id @default(cuid())
  tenantId          String?
  tenant            Tenant?          @relation(fields: [tenantId], references: [id])
  listingId         String
  listing           HostVehicleListing @relation(fields: [listingId], references: [id])
  reservationId     String?          @unique
  reservation       Reservation?     @relation(fields: [reservationId], references: [id])
  hostProfileId     String
  hostProfile       HostProfile      @relation("TripHost", fields: [hostProfileId], references: [id])
  guestCustomerId   String?
  guestCustomer     Customer?        @relation("TripGuestCustomer", fields: [guestCustomerId], references: [id])
  tripCode          String           @unique
  status            TripStatus       @default(RESERVED)
  scheduledPickupAt DateTime
  scheduledReturnAt DateTime
  actualPickupAt    DateTime?
  actualReturnAt    DateTime?
  pickupLocationId  String?
  pickupLocation    Location?        @relation("TripPickupLocation", fields: [pickupLocationId], references: [id])
  returnLocationId  String?
  returnLocation    Location?        @relation("TripReturnLocation", fields: [returnLocationId], references: [id])
  quotedSubtotal    Decimal          @default(0) @db.Decimal(10, 2)
  quotedTaxes       Decimal          @default(0) @db.Decimal(10, 2)
  quotedFees        Decimal          @default(0) @db.Decimal(10, 2)
  quotedTotal       Decimal          @default(0) @db.Decimal(10, 2)
  hostEarnings      Decimal          @default(0) @db.Decimal(10, 2)
  platformFee       Decimal          @default(0) @db.Decimal(10, 2)
  payoutHoldUntil   DateTime?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  payouts           TripPayout[]
  incidents         TripIncident[]
  timelineEvents    TripTimelineEvent[]

  @@index([tenantId, status, scheduledPickupAt])
  @@index([hostProfileId, status, scheduledPickupAt])
  @@index([guestCustomerId, status, scheduledPickupAt])
}

model AgreementDriver {
  id                String          @id @default(cuid())
  rentalAgreementId String
  rentalAgreement   RentalAgreement @relation(fields: [rentalAgreementId], references: [id], onDelete: Cascade)

  firstName         String
  lastName          String
  email             String?
  phone             String?
  licenseNumber     String?
  licenseState      String?
  licenseExpiry     DateTime?
  dateOfBirth       DateTime?
  isPrimary         Boolean         @default(false)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([rentalAgreementId, isPrimary])
}

model RentalAgreementCharge {
  id                String          @id @default(cuid())
  rentalAgreementId String
  rentalAgreement   RentalAgreement @relation(fields: [rentalAgreementId], references: [id], onDelete: Cascade)

  code              String?
  name              String
  chargeType        ChargeType      @default(UNIT)
  quantity          Decimal         @default(1) @db.Decimal(10, 2)
  rate              Decimal         @default(0) @db.Decimal(10, 2)
  total             Decimal         @default(0) @db.Decimal(10, 2)
  taxable           Boolean         @default(false)
  selected          Boolean         @default(true)
  sortOrder         Int             @default(0)
  source            String?
  sourceRefId       String?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  commissionLines   AgreementCommissionLine[]

  @@index([rentalAgreementId, selected])
}

model RentalAgreementPayment {
  id                String                 @id @default(cuid())
  rentalAgreementId String
  rentalAgreement   RentalAgreement        @relation(fields: [rentalAgreementId], references: [id], onDelete: Cascade)

  method            AgreementPaymentMethod
  amount            Decimal                @db.Decimal(10, 2)
  reference         String?
  status            PaymentStatus          @default(PAID)
  paidAt            DateTime               @default(now())
  notes             String?

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([rentalAgreementId, paidAt])
}

model CommissionPlan {
  id                  String               @id @default(cuid())
  tenantId            String?
  tenant              Tenant?              @relation(fields: [tenantId], references: [id])
  name                String
  isActive            Boolean              @default(true)
  defaultValueType    CommissionValueType?
  defaultPercentValue Decimal?             @db.Decimal(5, 2)
  defaultFixedAmount  Decimal?             @db.Decimal(10, 2)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  rules               CommissionRule[]
  agreementCommissions AgreementCommission[]
  assignedUsers       User[]               @relation("UserCommissionPlan")

  @@index([tenantId, isActive])
}

model CommissionRule {
  id                String               @id @default(cuid())
  commissionPlanId  String
  commissionPlan    CommissionPlan       @relation(fields: [commissionPlanId], references: [id], onDelete: Cascade)
  tenantId          String?
  tenant            Tenant?              @relation(fields: [tenantId], references: [id])
  name              String
  serviceId         String?
  service           AdditionalService?   @relation(fields: [serviceId], references: [id])
  chargeCode        String?
  chargeType        ChargeType?
  valueType         CommissionValueType
  percentValue      Decimal?             @db.Decimal(5, 2)
  fixedAmount       Decimal?             @db.Decimal(10, 2)
  priority          Int                  @default(0)
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([tenantId, isActive, priority])
  @@index([serviceId])
}

model AgreementCommission {
  id                String               @id @default(cuid())
  tenantId          String?
  tenant            Tenant?              @relation(fields: [tenantId], references: [id])
  rentalAgreementId String
  rentalAgreement   RentalAgreement      @relation(fields: [rentalAgreementId], references: [id], onDelete: Cascade)
  employeeUserId    String
  employeeUser      User                 @relation("AgreementCommissionEmployee", fields: [employeeUserId], references: [id])
  commissionPlanId  String?
  commissionPlan    CommissionPlan?      @relation(fields: [commissionPlanId], references: [id])
  status            CommissionStatus     @default(PENDING)
  monthKey          String
  grossRevenue      Decimal              @default(0) @db.Decimal(10, 2)
  serviceRevenue    Decimal              @default(0) @db.Decimal(10, 2)
  eligibleRevenue   Decimal              @default(0) @db.Decimal(10, 2)
  commissionAmount  Decimal              @default(0) @db.Decimal(10, 2)
  calculatedAt      DateTime             @default(now())
  approvedAt        DateTime?
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  lines             AgreementCommissionLine[]

  @@index([tenantId, monthKey, status])
  @@index([employeeUserId, monthKey])
  @@unique([rentalAgreementId, employeeUserId])
}

model AgreementCommissionLine {
  id                    String                @id @default(cuid())
  agreementCommissionId String
  agreementCommission   AgreementCommission   @relation(fields: [agreementCommissionId], references: [id], onDelete: Cascade)
  rentalAgreementChargeId String?
  rentalAgreementCharge RentalAgreementCharge? @relation(fields: [rentalAgreementChargeId], references: [id])
  serviceId             String?
  service               AdditionalService?    @relation(fields: [serviceId], references: [id])
  description           String
  quantity              Decimal               @default(1) @db.Decimal(10, 2)
  lineRevenue           Decimal               @default(0) @db.Decimal(10, 2)
  valueType             CommissionValueType
  percentValue          Decimal?              @db.Decimal(5, 2)
  fixedAmount           Decimal?              @db.Decimal(10, 2)
  commissionAmount      Decimal               @default(0) @db.Decimal(10, 2)
  createdAt             DateTime              @default(now())

  @@index([agreementCommissionId])
  @@index([serviceId])
}

model TripPayout {
  id                String            @id @default(cuid())
  tenantId          String?
  tenant            Tenant?           @relation(fields: [tenantId], references: [id])
  tripId            String
  trip              Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  hostProfileId     String
  hostProfile       HostProfile       @relation(fields: [hostProfileId], references: [id])
  status            TripPayoutStatus  @default(PENDING)
  grossTripAmount   Decimal           @default(0) @db.Decimal(10, 2)
  hostShareAmount   Decimal           @default(0) @db.Decimal(10, 2)
  platformFeeAmount Decimal           @default(0) @db.Decimal(10, 2)
  adjustmentsAmount Decimal           @default(0) @db.Decimal(10, 2)
  releasedAt        DateTime?
  holdReason        String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([tripId, status])
  @@index([hostProfileId, status, createdAt])
}

model TripIncident {
  id                String             @id @default(cuid())
  tripId            String
  trip              Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type              TripIncidentType
  status            TripIncidentStatus @default(OPEN)
  title             String
  description       String?
  amountClaimed     Decimal?           @db.Decimal(10, 2)
  amountResolved    Decimal?           @db.Decimal(10, 2)
  evidenceJson      String?
  resolvedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([tripId, status])
}

model TripTimelineEvent {
  id                String    @id @default(cuid())
  tripId            String
  trip              Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  eventType         String
  eventAt           DateTime  @default(now())
  actorType         String?
  actorRefId        String?
  notes             String?
  metadata          String?
  createdAt         DateTime  @default(now())

  @@index([tripId, eventAt])
}

model RentalAgreementInspection {
  id                String            @id @default(cuid())
  rentalAgreementId String
  rentalAgreement   RentalAgreement   @relation(fields: [rentalAgreementId], references: [id], onDelete: Cascade)

  phase             InspectionPhase
  capturedAt        DateTime          @default(now())
  actorUserId       String?
  actorIp           String?

  exterior          String?
  interior          String?
  tires             String?
  lights            String?
  windshield        String?
  fuelLevel         String?
  odometer          Int?
  damages           String?
  notes             String?
  photosJson        String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([rentalAgreementId, phase])
  @@index([rentalAgreementId, capturedAt])
}

model ReservationPricingSnapshot {
  id                      String      @id @default(cuid())
  reservationId           String      @unique
  reservation             Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  dailyRate               Decimal?    @db.Decimal(10, 2)
  taxRate                 Decimal?    @db.Decimal(5, 2)

  selectedInsuranceCode   String?
  selectedInsuranceName   String?

  depositRequired         Boolean     @default(false)
  depositMode             String?
  depositValue            Decimal?    @db.Decimal(10, 2)
  depositBasisJson        String?
  depositAmountDue        Decimal     @default(0) @db.Decimal(10, 2)

  securityDepositRequired Boolean     @default(false)
  securityDepositAmount   Decimal     @default(0) @db.Decimal(10, 2)

  source                  String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model ReservationCharge {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  code          String?
  name          String
  chargeType    ChargeType  @default(UNIT)
  quantity      Decimal     @default(1) @db.Decimal(10, 2)
  rate          Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @default(0) @db.Decimal(10, 2)
  taxable       Boolean     @default(false)
  selected      Boolean     @default(true)
  sortOrder     Int         @default(0)

  source        String?
  sourceRefId   String?
  notes         String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([reservationId, selected, sortOrder])
}

model ReservationPayment {
  id                      String                   @id @default(cuid())
  reservationId           String
  reservation             Reservation              @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  method                  AgreementPaymentMethod
  amount                  Decimal                  @db.Decimal(10, 2)
  reference               String?
  status                  PaymentStatus            @default(PAID)
  paidAt                  DateTime                 @default(now())

  origin                  ReservationPaymentOrigin @default(OTC)
  gateway                 String?
  notes                   String?

  rentalAgreementPaymentId String?

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([reservationId, paidAt])
  @@index([reference])
}

model ReservationAdditionalDriver {
  id                  String      @id @default(cuid())
  reservationId       String
  reservation         Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  firstName           String
  lastName            String
  address             String?
  dateOfBirth         DateTime?
  licenseNumber       String?
  licenseImageUploaded Boolean    @default(false)
  notes               String?

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([reservationId, createdAt])
}

model Rate {
  id                String    @id @default(cuid())
  tenantId          String?
  tenant            Tenant?   @relation(fields: [tenantId], references: [id])
  rateCode          String    @unique
  name              String?
  locationId        String?
  location          Location? @relation(fields: [locationId], references: [id])
  locationIds       String?
  rateType          RateType  @default(MULTIPLE_CLASSES)
  calculationBy     String    @default("24_HOUR_TIME")
  averageBy         String?   @default("DATE_RANGE")
  daily             Decimal   @default(0) @db.Decimal(10, 2)
  fuelChargePerGallon Decimal? @db.Decimal(10, 2)
  minChargeDays     Int?
  minChargeHours    Int?
  grossFlatNumber   Decimal?  @db.Decimal(10, 2)
  extraMileCharge   Decimal?  @db.Decimal(10, 2)
  graceMinutes      Int?
  useHourlyRates    Boolean   @default(false)
  active            Boolean   @default(true)
  displayOnline     Boolean   @default(false)
  variesPricing     Boolean   @default(false)
  sameSpecialRates  Boolean   @default(false)
  rencarscom        Boolean   @default(false)
  monday            Boolean   @default(true)
  tuesday           Boolean   @default(true)
  wednesday         Boolean   @default(true)
  thursday          Boolean   @default(true)
  friday            Boolean   @default(true)
  saturday          Boolean   @default(true)
  sunday            Boolean   @default(true)
  effectiveDate     DateTime?
  endDate           DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rateItems         RateItem[]

  @@index([locationId, isActive])
}

model RateItem {
  id              String    @id @default(cuid())
  rateId          String
  rate            Rate      @relation(fields: [rateId], references: [id], onDelete: Cascade)
  vehicleTypeId   String
  vehicleType     VehicleType @relation(fields: [vehicleTypeId], references: [id])
  hourly          Decimal   @default(0) @db.Decimal(10, 2)
  daily           Decimal   @default(0) @db.Decimal(10, 2)
  extraDaily      Decimal   @default(0) @db.Decimal(10, 2)
  weekly          Decimal   @default(0) @db.Decimal(10, 2)
  monthly         Decimal   @default(0) @db.Decimal(10, 2)
  minHourly       Int       @default(0)
  minDaily        Int       @default(0)
  minWeekly       Int       @default(0)
  minMonthly      Int       @default(0)
  extraMileCharge Decimal   @default(0) @db.Decimal(10, 2)
  sortOrder       Int       @default(0)

  @@unique([rateId, vehicleTypeId])
}

model Fee {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  code        String?  @unique
  name        String
  description String?
  mode        FeeMode
  amount      Decimal  @default(0) @db.Decimal(10, 2)
  taxable       Boolean  @default(false)
  isActive      Boolean  @default(true)
  isUnderageFee       Boolean  @default(false)
  isAdditionalDriverFee Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  locationFees LocationFee[]

  @@index([isActive, name])
}

model LocationFee {
  locationId String
  feeId      String
  createdAt  DateTime @default(now())

  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  fee        Fee      @relation(fields: [feeId], references: [id], onDelete: Cascade)

  @@id([locationId, feeId])
}

model AdditionalService {
  id              String    @id @default(cuid())
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  code            String?
  name            String
  description     String?
  chargeType      ChargeType @default(UNIT)
  unitLabel       String?   @default("Unit")
  calculationBy   String    @default("24_HOUR_TIME")
  rate            Decimal   @default(0) @db.Decimal(10, 2)
  dailyRate       Decimal?  @db.Decimal(10, 2)
  weeklyRate      Decimal?  @db.Decimal(10, 2)
  monthlyRate     Decimal?  @db.Decimal(10, 2)
  commissionValueType   CommissionValueType?
  commissionPercentValue Decimal? @db.Decimal(5, 2)
  commissionFixedAmount  Decimal? @db.Decimal(10, 2)
  taxable         Boolean   @default(false)
  defaultQty      Decimal   @default(1) @db.Decimal(10, 2)
  sortOrder       Int       @default(0)
  allVehicleTypes Boolean   @default(true)
  vehicleTypeIds  String?
  displayOnline   Boolean   @default(false)
  defaultRencars  Boolean   @default(false)
  mandatory       Boolean   @default(false)
  isActive        Boolean   @default(true)

  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  commissionRules CommissionRule[]
  commissionLines AgreementCommissionLine[]

  @@index([locationId, isActive])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

