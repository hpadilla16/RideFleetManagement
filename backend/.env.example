# Example
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fleet_management?schema=public"
PORT=4000
JWT_SECRET="change-this-secret"
JWT_EXPIRES_IN="12h"
ALLOW_PUBLIC_REGISTER="false"
SENTRY_DSN=""
SENTRY_ENV="production"
SENTRY_RELEASE=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
# Example
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fleet_management?schema=public"
PORT=4000
JWT_SECRET="change-this-secret"
JWT_EXPIRES_IN="12h"
ALLOW_PUBLIC_REGISTER="false"
SENTRY_DSN=""
SENTRY_ENV="production"
SENTRY_RELEASE=""
SENTRY_TRACES_SAMPLE_RATE="0.1"

# Performance tuning (defaults are sane; override only when you know why)
# Connection pool size appended to DATABASE_URL when not already present.
# Default 30 (raised from 20 for ~15-20 concurrent staff users on one tenant).
DATABASE_POOL_SIZE="30"
# Pool acquisition timeout in seconds. Default 10.
DATABASE_POOL_TIMEOUT="10"
# Threshold (ms) above which Prisma queries log a warn line. Set to 0 to disable.
PRISMA_SLOW_QUERY_MS="200"
# Threshold (ms) above which HTTP requests log a warn line + drop a Sentry breadcrumb.
SLOW_REQUEST_MS="1000"

# Optional Redis pub/sub for cross-worker cache invalidation (Phase 3 L-1).
# When set, every cache.del / cache.invalidate / cache.clear is broadcast
# to other workers/instances so they can drop their local copies. Reads
# stay in-memory and synchronous — Redis is invalidation-only, not a
# read-through L2. Leave unset for single-worker / single-instance prod.
REDIS_URL=""
REDIS_INVALIDATION_CHANNEL="fleet:cache-invalidate"
