{
  "name": "fleet-management-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node src/main.js",
    "start": "node src/main.js",
    "start:cluster": "node src/cluster.js",

   "test": "npm run test:vehicles && npm run test:fees && npm run test:booking-engine && npm run test:stop-sales && npm run test:review-email && npm run test:public-booking && npm run test:planner && npm run test:rates && npm run test:portal && npm run test:carsharing && npm run test:issues && npm run test:tolls && npm run test:sms && npm run test:payments && npm run test:auth && npm run test:cache && npm run test:commissions && npm run test:puppeteer && npm run test:rental-agreements",

    "test:vehicles": "node --test src/modules/vehicles/vehicle-intelligence.test.mjs src/modules/vehicles/telematics-zubie.test.mjs",
    "test:fees": "node --test src/modules/fees/fees.test.mjs",
    "test:booking-engine": "node --test src/modules/booking-engine/booking-engine.test.mjs",
    "test:stop-sales": "node --test src/modules/stop-sales/stop-sales.test.mjs",
    "test:review-email": "node --test src/modules/reservations/review-email.test.mjs",
    "test:public-booking": "node --test src/modules/public-booking/public-booking.test.mjs",
    "test:planner": "node --test src/modules/planner/planner.service.test.mjs",
    "test:rates": "node --test src/modules/rates/revenue-pricing.test.mjs",
    "test:portal": "node --test src/modules/customer-portal/customer-portal-self-service.test.mjs",
    "test:carsharing": "node --test src/modules/car-sharing/car-sharing-fulfillment.test.mjs src/modules/car-sharing/car-sharing-handoff.test.mjs",
    "test:issues": "node --test src/modules/issue-center/issue-center-attachments.test.mjs src/modules/issue-center/issue-center-claims-fields.test.mjs src/modules/issue-center/issue-center-packets.test.mjs src/modules/issue-center/issue-center-packet-html.test.mjs src/modules/issue-center/issue-center-next-best-action.test.mjs src/modules/issue-center/issue-center-workflow-actions.test.mjs src/modules/issue-center/issue-center-evidence-checklist.test.mjs src/modules/issue-center/issue-center-evidence-capture.test.mjs src/modules/issue-center/issue-center-evidence-request.test.mjs src/modules/issue-center/issue-center-request-workflow.test.mjs src/modules/issue-center/issue-center-recovery-actions.test.mjs src/modules/issue-center/issue-center-inspection-compare.test.mjs src/modules/issue-center/issue-center-charge-draft.test.mjs",
    "test:tolls": "node --test src/modules/tolls/tolls-responsibility.test.mjs src/modules/tolls/tolls-billing-policy.test.mjs",
    "test:sms": "node --test src/modules/sms/sms-templates.test.mjs",
    "test:payments": "node --test src/modules/payment-gateway/spin-client.test.mjs",
    "test:auth": "node --test src/modules/auth/auth-validation.test.mjs",
    "test:cache": "node --test src/lib/cache.test.mjs",
    "test:puppeteer": "node --test src/lib/puppeteer-browser.test.mjs",
    "test:rental-agreements": "node --test src/modules/rental-agreements/rental-agreements-email-async.test.mjs src/modules/rental-agreements/rental-agreements-finalize-tx.test.mjs",
    "test:commissions": "node --test src/modules/commissions/car-sharing-commission.test.mjs",
    "test:public-booking": "node --test src/modules/public-booking/payment-session.test.mjs src/modules/public-booking/payarc-hosted-fields.test.mjs",
    "verify": "npm run test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "seed:bootstrap": "node scripts/seed-bootstrap.mjs",
    "seed:booking-fixtures": "node scripts/seed-booking-fixtures.mjs",
    "verify:booking-fixtures": "node scripts/verify-booking-fixtures.mjs",
    "backfill:legacy-metadata": "node scripts/backfill-legacy-metadata.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "@sentry/node": "^10.46.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.39.1",
    "stripe": "^16.10.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "prisma": "^6.14.0"
  }
